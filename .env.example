# Sanity CMS Configuration
# Get these values from https://www.sanity.io/manage
PUBLIC_SANITY_PROJECT_ID=your-project-id-here
PUBLIC_SANITY_DATASET=production

# Sanity API Token (for preview/draft mode)
# Create a token with "Viewer" permission at https://www.sanity.io/manage
SANITY_API_TOKEN=your-api-token-here
