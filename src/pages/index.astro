---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero';
import LocationSearch from '../components/LocationSearch';
import VideoSection from '../components/VideoSection';
import ThreeThings from '../components/ThreeThings';
import MannaApp from '../components/MannaApp';
import Footer from '../components/Footer';
import {loadQuery} from '../lib/load-query';

export const prerender = false;

// Fetch homepage content from Sanity with visual editing support
const {data: homeContent} = await loadQuery({
  query: `*[_type == "siteContent" && _id == "homepage"][0] {
    _id,
    heroTitle,
    heroSubtitle,
    "heroBackgroundImage": heroBackgroundImage.asset->url,
    "heroLogo": heroLogo.asset->url,
    "heroCollageImages": heroCollageImages[].asset->url,
    "videoUrl": videoUrl.asset->url,
    videoText,
    threeThingsTitle,
    threeThingsDescription,
    threeThingsCards[] {
      eyebrow,
      title,
      body,
      "icon": icon.asset->url
    },
    appTitle,
    appSubtitle,
    appFeatures[] {
      feature
    },
    "appMockupImage": appMockupImage.asset->url,
    appStoreUrl,
    playStoreUrl
  }`,
});

// Fetch locations for the search section
const {data: locations} = await loadQuery({
  query: `*[_type == "location"] | order(name asc) {
    _id,
    name,
    slug,
    type,
    city,
    state,
    "image": featuredImage.asset->url
  }`,
});
---

<BaseLayout>
  <main>
    <Hero
      client:load
      content={homeContent}
    />
    <LocationSearch
      client:load
      locations={locations}
    />
    <VideoSection
      client:load
      content={homeContent}
    />
    <ThreeThings
      client:load
      content={homeContent}
    />
    <MannaApp
      client:load
      content={homeContent}
    />
    <Footer client:load />
  </main>
</BaseLayout>
