{
  "name": "manna-church-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:studio && astro build && npm run copy:studio",
    "build:studio": "cd studio && npm install && SANITY_STUDIO_BASE_PATH=/studio npm run build",
    "copy:studio": "mkdir -p dist/studio && cp -r studio/dist/* dist/studio/",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/vercel": "^11.0.2",
    "@sanity/client": "^7.23.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/overlays": "^2.3.59",
    "@sanity/visual-editing": "^5.4.5",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "xml2js": "^0.6.2"
  }
}
